

GYC_INSTALL_NAME := $(shell echo gyc|sed '$(program_transform_name)')
GYC_TARGET_INSTALL_NAME := $(target_noncanonical)-$(shell echo gyc|sed '$(program_transform_name)')

ymir: ymir1$(exeext)
 
.PHONY: ymir

GYC_INCLUDES = -I$(srcdir)/../include -I$(srcdir)/ -I$(srcdir)/gcc -I../gcc -I$(srcdir)/../libcpp/include
BGYC_INCLUDES = -I$(srcdir)/ymir/ymirc -I../gcc/ymir/ymirc

CFLAGS-ymir/gycspec.o += $(DRIVER_DEFINES)

# Driver
GYC_OBJS = $(GCC_OBJS) ymir/gycspec.o
 
gyc$(exeext): $(GYC_OBJS) $(EXTRA_GCC_OBJS) libcommon-target.a $(LIBDEPS) insn-modes.h
	+$(LINKER) $(ALL_LINKERFLAGS) $(LDFLAGS) $(GYC_INCLUDES) -o $@ \
	  $(GYC_OBJS) $(EXTRA_GCC_OBJS) libcommon-target.a \
	  $(EXTRA_GCC_LIBS) $(LIBS)


WARN_YFLAGS = -Wall -Wdeprecated $(NOCOMMON_FLAG)
ALL_YFLAGS = $(PICFLAG) $(ALIASING_FLAGS) $(COVERAGE_FLAGS) $(WARN_YFLAGS) -O3

ALL_BYFLAGS = -O3

YCOMPILE.base = $(CXX) $(NO_PIE_CFLAGS) -c $(ALL_YFLAGS) -o $@
YCOMPILE = $(YCOMPILE.base) -MT $@ -MMD -MP -MF $(@D)/$(DEPDIR)/$(*F).TPo 
YPOSTCOMPILE = @mv $(@D)/$(DEPDIR)/$(*F).TPo $(@D)/$(DEPDIR)/$(*F).Po
YLINKER = $(CXX) $(NO_PIE_CFLAG) -lstdc++

BYCOMPILE = gyc -c $(ALL_BYFLAGS) -o $@
BYLINKER = gyc -lgmidgard

# The compiler proper
 
ymir_OBJS = \
	ymir/errors__.o \
	ymir/errors_format.o \
	ymir/errors_message.o \
	ymir/options_state.o \
	ymir/parsing_Parser.o \
	ymir/syntax_declaration__.o \
	ymir/syntax_declaration_aka_.o \
	ymir/syntax_declaration_attributes.o \
	ymir/syntax_declaration_class_.o \
	ymir/syntax_declaration_condblock.o \
	ymir/syntax_declaration_constructor.o \
	ymir/syntax_declaration_declblock.o \
	ymir/syntax_declaration_enum_.o \
	ymir/syntax_declaration_externblock.o \
	ymir/syntax_declaration_function.o \
	ymir/syntax_declaration_global.o \
	ymir/syntax_declaration_impl_.o \
	ymir/syntax_declaration_import_.o \
	ymir/syntax_declaration_macro_.o \
	ymir/syntax_declaration_module.o \
	ymir/syntax_declaration_protection.o \
	ymir/syntax_declaration_struct_.o \
	ymir/syntax_declaration_template.o \
	ymir/syntax_declaration_trait_.o \
	ymir/syntax_decorators.o \
	ymir/syntax_expression__.o \
	ymir/syntax_expression_assert_.o \
	ymir/syntax_expression_atomic_.o \
	ymir/syntax_expression_block.o \
	ymir/syntax_expression_break_.o \
	ymir/syntax_expression_cast_.o \
	ymir/syntax_expression_conditional.o \
	ymir/syntax_expression_decoexpr.o \
	ymir/syntax_expression_destrdecl.o \
	ymir/syntax_expression_for_.o \
	ymir/syntax_expression_funcptr.o \
	ymir/syntax_expression_list.o \
	ymir/syntax_expression_literals.o \
	ymir/syntax_expression_macro_.o \
	ymir/syntax_expression_matcher.o \
	ymir/syntax_expression_operators.o \
	ymir/syntax_expression_pragma.o \
	ymir/syntax_expression_return_.o \
	ymir/syntax_expression_slice.o \
	ymir/syntax_expression_template.o \
	ymir/syntax_expression_throw_.o \
	ymir/syntax_expression_unit.o \
	ymir/syntax_expression_var.o \
	ymir/syntax_expression_while_.o \
	ymir/syntax_expression_with_.o \
	ymir/syntax_tokenizer.o \
	ymir/syntax_lexer.o \
	ymir/syntax_keys.o \
	ymir/syntax_node.o \
	ymir/syntax_tokens.o \
	ymir/syntax_word.o \
	ymir/utils_stream.o \
	ymir/utils_string.o \
	ymir/ymir1.o \
	ymir/ymirc_main.o \
	$(END)	

ymir1$(exeext): attribs.o $(ymir_OBJS) $(BACKEND) $(LIBDEPS)
	+$(LLINKER) $(ALL_LINKERFLAGS) $(LDFLAGS) -o $@ \
	attribs.o $(ymir_OBJS) $(BACKEND) $(LIBS) $(BACKENDLIBS) -lgymidgard -lgyruntime -lgc
 
ymir.all.cross: 
 
ymir.start.encap: gyc$(exeext)
ymir.rest.encap:

selftest-ymir:

ymir.install-common: installdirs
	-rm -f $(DESTDIR)$(bindir)/$(GYC_INSTALL_NAME)$(exeext)
	$(INSTALL_PROGRAM) gyc$(exeext) $(DESTDIR)$(bindir)/$(GYC_INSTALL_NAME)$(exeext)
	rm -f $(DESTDIR)$(bindir)/$(GYC_TARGET_INSTALL_NAME)$(exeext); \
	( cd $(DESTDIR)$(bindir) && \
      $(LN) $(GYC_INSTALL_NAME)$(exeext) $(GYC_TARGET_INSTALL_NAME)$(exeext) ); \
 
# Required goals, they still do nothing
ymir.install-man:
ymir.install-info:
ymir.install-pdf:
ymir.install-plugin:
ymir.install-html:
ymir.info:
ymir.dvi:
ymir.pdf:
ymir.html:
ymir.man:
ymir.mostlyclean:
ymir.clean:
ymir.distclean:
ymir.maintainer-clean:


# make uninstall
ymir.uninstall:

	-rm -f gyc$(exeext) ymir1$(exeext)
	-rm -f $(ymir_OBJS)
 
# Used for handling ymirc
ymir.stage1: stage1-start
	-mv ymir/*$(objext) stage1/ymir
ymir.stage2: stage2-start
	-mv ymir/*$(objext) stage2/ymir
ymir.stage3: stage3-start
	-mv ymir/*$(objext) stage3/ymir
ymir.stage4: stage4-start
	-mv ymir/*$(objext) stage4/ymir
ymir.stageprofile: stageprofile-start
	-mv ymir/*$(objext) stageprofile/ymir
ymir.stagefeedback: stagefeedback-start
	-mv ymir/*$(objext) stagefeedback/ymir

ymir/parsing_%.o: ymir/parsing/%.cc
	  $(YCOMPILE) $(GYC_INCLUDES) $<
	  $(YPOSTCOMPILE)

ymir/ymirc_%.o: ymir/ymirc/%.yr
	  $(BYCOMPILE) $(BGYC_INCLUDES) $<

ymir/options_%.o: ymir/ymirc/options/%.yr
	  $(BYCOMPILE) $(BGYC_INCLUDES) $<

ymir/utils_%.o: ymir/ymirc/utils/%.yr
	  $(BYCOMPILE) $(BGYC_INCLUDES) $<

ymir/syntax_%.o: ymir/ymirc/syntax/%.yr
	  $(BYCOMPILE) $(BGYC_INCLUDES) $<

ymir/syntax_expression_%.o: ymir/ymirc/syntax/expression/%.yr
	  $(BYCOMPILE) $(BGYC_INCLUDES) $<

ymir/syntax_declaration_%.o: ymir/ymirc/syntax/declaration/%.yr
	  $(BYCOMPILE) $(BGYC_INCLUDES) $<

ymir/errors_%.o: ymir/ymirc/errors/%.yr
	  $(BYCOMPILE) $(BGYC_INCLUDES) $<
