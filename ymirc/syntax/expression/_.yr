mod syntax::expression::_;

import syntax::word;
import syntax::node;

/**
 * Ancestor class of all expressions
 */
pub class @abstract Expression over SyntaxNode {

    /**
     * @params: 
     *   - loc: the location of the expression
     */
    pub self (loc : &Word) with super (loc)
    {}
    
}

