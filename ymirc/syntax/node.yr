mod syntax::node;

import syntax::word;
import utils::stream;
import std::io;

pub class @abstract SyntaxNode {

    let _loc : &Word;

    pub self (loc : &Word) with _loc = loc
    {}
    
    pub def getLoc (self)-> &Word {
        self._loc
    }
    
    impl utils::stream::Streamable;
    
    impl std::io::Printable;        

}
