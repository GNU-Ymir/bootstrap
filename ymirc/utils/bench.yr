mod utils::bench;

import utils::stream;
import utils::logs;
import std::conv;

enum
| CLOCKS_PER_SEC = 1_000_000.0
 -> ClockCst;

extern (C) def clock ()-> u64;

pub def now ()-> f64 {
    clock ().to!f64 ()
}

pub def bench {T...} (name : [c8], foo : fn (T)-> void, t : T) -> void {
    logging::init ();
    let b = now ();
    foo (expand t);
    let e = now () - b;
    logging::info (format ("bench %(b) took %(y)s"s8, name, e / ClockCst::CLOCKS_PER_SEC));
}


    
